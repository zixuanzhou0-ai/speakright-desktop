{
  "name": "speakright-desktop",
  "version": "1.0.1",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zixuanzhou0-ai/speakright.git"
  },
  "homepage": "https://github.com/zixuanzhou0-ai/speakright#readme",
  "bugs": {
    "url": "https://github.com/zixuanzhou0-ai/speakright/issues"
  },
  "scripts": {
    "dev": "tauri dev",
    "desktop:dev": "tauri dev",
    "dev:web:desktop": "next dev --turbopack --port 3002",
    "dev:browser": "npm --prefix apps/browser run dev",
    "build": "node scripts/desktop-build.mjs",
    "desktop:build": "node scripts/desktop-build.mjs",
    "build:desktop-frontend": "next build",
    "build:browser": "npm --prefix apps/browser run build",
    "serve:browser": "npm --prefix apps/browser run serve:static",
    "browser:serve-static": "npm --prefix apps/browser run serve:static",
    "desktop:preflight": "node scripts/desktop-preflight.mjs",
    "desktop:preflight:build": "node scripts/desktop-preflight.mjs --allow-missing-release-exe",
    "desktop:launch-release": "node scripts/desktop-launch-release.mjs",
    "desktop:run-release": "npm run desktop:build && npm run desktop:launch-release",
    "lint": "biome lint .",
    "lint:browser": "npm --prefix apps/browser run lint",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "tsc --noEmit",
    "typecheck:browser": "npm --prefix apps/browser run typecheck",
    "test": "vitest run",
    "test:browser": "npm --prefix apps/browser run test",
    "tauri:check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "tauri:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "desktop:artifact-smoke": "node scripts/desktop-artifact-smoke.mjs",
    "desktop:smoke": "node scripts/desktop-smoke.mjs",
    "desktop:ui-smoke": "node scripts/desktop-ui-smoke.mjs",
    "desktop:live-validation": "node scripts/desktop-live-validation.mjs --azure-mode=high",
    "desktop:live-validation:full": "node scripts/desktop-live-validation.mjs --azure-mode=full",
    "browser:smoke": "npm --prefix apps/browser run browser:smoke",
    "browser:smoke:static": "npm --prefix apps/browser run browser:smoke:static",
    "browser:azure-live-log": "node scripts/browser-azure-live-log.mjs",
    "audio:loudness:dry-run": "node scripts/audio-loudness-audit.mjs --dry-run",
    "audio:parity:dry-run": "node scripts/multilingual-audio-parity-report.mjs --dry-run",
    "audio:parity:generate": "node scripts/multilingual-audio-parity-generate.mjs --confirm",
    "audio:parity:secondary:dry-run": "node scripts/multilingual-audio-secondary-voice-generate.mjs --dry-run",
    "audio:parity:generate-secondary": "node scripts/multilingual-audio-secondary-voice-generate.mjs --confirm --max-items 1600 --max-estimated-credits 40000",
    "release:size:audit": "node scripts/release-size-audit.mjs",
    "ipa:audit:export": "node scripts/export-non-english-ipa-audit-input.mjs",
    "ipa:practice:audit:export": "node scripts/export-phoneme-practice-ipa-audit-input.mjs",
    "phonology:inventory:export": "node scripts/export-phonology-inventory-tables.mjs",
    "phonology:inventory:check": "node scripts/export-phonology-inventory-tables.mjs --check",
    "phonology:audio-policy:export": "node scripts/export-assessment-audio-policy-tables.mjs",
    "phonology:audio-policy:check": "node scripts/export-assessment-audio-policy-tables.mjs --check",
    "video:compress:dry-run": "node scripts/compress-videos.mjs --dry-run",
    "video:compress": "node scripts/compress-videos.mjs --confirm",
    "desktop:release-report": "node scripts/desktop-release-report.mjs",
    "desktop:installer-smoke": "node scripts/desktop-installer-smoke.mjs",
    "desktop:release-gate": "node scripts/desktop-release-gate.mjs",
    "docs:check-links": "node scripts/check-doc-links.mjs",
    "validate": "npm run lint && npm run typecheck && npm run test",
    "validate:browser": "npm --prefix apps/browser run validate:browser",
    "validate:desktop-ci": "npm run validate && npm run desktop:preflight:build && npm run tauri:check && npm run tauri:test && npm run desktop:build && npm run desktop:artifact-smoke && npm run desktop:release-report && npm run desktop:installer-smoke",
    "validate:desktop": "npm run validate && npm run desktop:preflight:build && npm run tauri:check && npm run tauri:test && npm run desktop:build && npm run desktop:artifact-smoke && npm run desktop:ui-smoke && npm run desktop:smoke && npm run desktop:release-report && npm run desktop:installer-smoke",
    "validate:internal-release": "npm run validate:desktop",
    "validate:release": "npm run validate:desktop && npm run desktop:release-gate",
    "validate:public-release": "npm run validate:release"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-http": "^2.5.7",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-store": "^2.4.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "howler": "^2.2.4",
    "lucide-react": "^1.0.1",
    "motion": "^12.38.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "wavesurfer.js": "^7.12.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@tailwindcss/postcss": "^4",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/howler": "^2.2.12",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
