{
  "$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**",
      "!!**/.next",
      "!!**/out",
      "!!**/node_modules",
      "!!**/coverage",
      "!!**/build",
      "!!**/.runlogs",
      "!!**/.playwright-mcp",
      "!!src-tauri/target",
      "!!src-tauri/gen",
      "!!apps/desktop",
      "!!apps/browser/biome.json",
      "!!docs/operations/non-english-ipa-audit-input.json",
      "!!docs/operations/phoneme-practice-ipa-audit-input.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
