{
  "name": "speakright-browser",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "description": "SpeakRight Browser Edition: cross-platform local browser pronunciation practice.",
  "repository": {
    "type": "git",
    "url": "https://github.com/zixuanzhou0-ai/speakright.git"
  },
  "homepage": "https://github.com/zixuanzhou0-ai/speakright#readme",
  "bugs": {
    "url": "https://github.com/zixuanzhou0-ai/speakright/issues"
  },
  "scripts": {
    "dev": "next dev --turbopack --port 3000",
    "build": "next build",
    "build:static": "next build",
    "serve:static": "node scripts/serve-static.mjs",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "browser:smoke": "node scripts/browser-smoke.mjs",
    "browser:smoke:static": "node scripts/browser-smoke-static.mjs",
    "azure:live-log": "node ../../scripts/browser-azure-live-log.mjs",
    "validate": "npm run lint && npm run typecheck && npm run test",
    "validate:browser": "npm run validate && npm run build && npm run browser:smoke:static"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "howler": "^2.2.4",
    "lucide-react": "^1.0.1",
    "microsoft-cognitiveservices-speech-sdk": "^1.50.0",
    "motion": "^12.38.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "wavesurfer.js": "^7.12.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/howler": "^2.2.12",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
