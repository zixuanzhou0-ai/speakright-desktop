# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.tauri-dev-run.log
.runlogs/

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo

# playwright MCP artifacts
.playwright-mcp/

# root-level screenshots (dev debugging artifacts)
/*.png
/*.jpg
/*.jpeg

# phoneme teaching videos (Rachel's English, ~230MB)
/public/videos/phonemes/
